# =====================================
# GreatonMedical Portal - Environment
# =====================================

# App environment: 'local' (dev) or 'production'
APP_ENV=local

# Random string for session security (min 32 chars)
# Generate with: openssl rand -hex 32
APP_SECRET=local_dev_secret_replace_with_random_string_32_chars_min

# Mock mode - true = simulate monday API without real calls (for local dev)
# Set to false when you have a real monday API token
MOCK_MONDAY=true

# Monday API token (only needed when MOCK_MONDAY=false)
# Get it at: monday.com → avatar → Developers → My Access Tokens
MONDAY_API_TOKEN=
