# =====================================
# Client Portal — Environment Template
# =====================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# App environment: 'local' (dev) or 'production'
APP_ENV=local

# Random string for session security (min 32 chars)
# Generate with: openssl rand -hex 32
APP_SECRET=change_me_generate_with_openssl_rand_hex_32

# ── Brand ─────────────────────────────────────────────────────────────────────

# Agency / portal identity
AGENCY_NAME=Your Agency
APP_NAME=Your Agency Client Portal
APP_URL=https://clients.yourdomain.com

# Hex colors for the portal UI
BRAND_PRIMARY_COLOR=#6366f1
BRAND_SECONDARY_COLOR=#111827
# Light tint of primary used for hover backgrounds (mix primary ~12% with white)
BRAND_PRIMARY_LIGHT=#eef2ff

# 1–3 character initials rendered as the default logo (used when BRAND_LOGO_PATH is empty)
BRAND_LOGO_INITIALS=A

# Agency logo — set to an external URL or a web-root-relative path (e.g. /assets/brand/logo.svg)
# The src/assets/brand/ folder is the conventional local location; add a .gitkeep there.
# Leave empty to show initials instead.
BRAND_LOGO_PATH=

# Browser tab favicon URL (can be external CDN or local path)
FAVICON_URL=

# ── Database ──────────────────────────────────────────────────────────────────

DB_NAME=portal_db
DB_USER=portal_user
DB_PASS=portal_pass
# DB_HOST defaults to 'db' (Docker service name); override for Cloudways or remote MySQL
# DB_HOST=db

# ── Monday.com ────────────────────────────────────────────────────────────────

# true = simulate all API calls locally (no real monday account needed)
MOCK_MONDAY=true

# monday.com API token (required when MOCK_MONDAY=false)
# Get it at: monday.com → avatar → Developers → My Access Tokens
MONDAY_API_TOKEN=

# monday.com account subdomain — used to build direct item links in the admin panel
# e.g. "myagency" for myagency.monday.com
MONDAY_DOMAIN=
